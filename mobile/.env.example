# Backend API base URL.
#
# - iOS simulator: http://localhost:8000/api works fine.
# - Android emulator: use http://10.0.2.2:8000/api (localhost on the emulator
#   points at the emulator itself, not your dev machine).
# - Physical device (Expo Go): use your dev machine's LAN IP, e.g.
#   http://192.168.1.23:8000/api. The device and machine must be on the same
#   network, and `php artisan serve --host=0.0.0.0` must be running so the
#   backend accepts connections from outside localhost.
EXPO_PUBLIC_API_URL=http://localhost:8000/api
